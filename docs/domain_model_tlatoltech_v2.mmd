classDiagram
%% Definición de Enumeradores (Value Objects)
    class EstadoMembresia {
        <<enumeration>>
        ACTIVO
        INACTIVO
        VENCIDO
        CANCELADO
    }
    class EstadoSesion {
        <<enumeration>>
        EN_PROGRESO
        FINALIZADA
    }
    class RolUsuario {
        <<enumeration>>
        CLIENTE
        ENTRENADOR
        DUEÑO
        RECEPCIONISTA
    }
%% Enumeradores Transicionales
    class EstadoQueja {
        <<enumeration>>
        ABIERTA
        EN_REVISION
        RESUELTA
    }
    class EstadoSolicitud {
        <<enumeration>>
        PENDIENTE
        APROBADA
        RECHAZADA
    }

%% Jerarquía de Usuarios
    class Usuario {
        <<abstract>>
        #UUID id
        #String nombre
        #String correo
        #String passwordHash
        #RolUsuario rol
        +autenticar(password: String): boolean
    }

    class Cliente {
        -List~Usuario~ seguidos
        -Entrenador entrenadorAsignado
        +registrarDatosCorporales(peso: float, altura: float, grasa: float): void
        +seguirUsuario(u: Usuario): void
        +solicitarCambioEntrenador(nuevoEntrenador: Entrenador): SolicitudEntrenador
        +redactarQueja(detalle: String): Queja
    }

    class Entrenador {
        -int limiteClientes
        -List~Cliente~ clientesAsignados
        +asignarRutina(c: Cliente, r: Rutina): void
        +puedeAceptarCliente(): boolean
    }

    class Dueno {
        +registrarNuevaSucursal(datos: Sucursal): void
        +revisarQuejasPendientes(): List~Queja~
    }

    Usuario <|-- Cliente
    Usuario <|-- Entrenador
    Usuario <|-- Dueno
%% Nuevo Agregado: Sucursal y Accesos
    class Sucursal {
        <<AggregateRoot>>
        -UUID id
        -String nombre
        -String direccion
        -List~Usuario~ usuariosAsignados
        +registrarEntrada(c: Cliente): RegistroAcceso
        +asignarUsuario(u: Usuario): void
    }

%% Agregado: Evolución Física
    class DatosCorporales {
        <<ValueObject>>
        -LocalDate fecha
        -float peso
        -float altura
        -float porcentajeGrasa
        +calcularIMC(): float
    }
    Cliente *-- DatosCorporales

    class RegistroAcceso {
        <<Entity>>
        -UUID id
        -LocalDateTime fechaHora
        -String metodoValidacion
        -boolean accesoExitoso
    }

    Sucursal "1" *-- "*" RegistroAcceso: audita
    RegistroAcceso "*" --> "1" Cliente: pertenece a
    Dueno "1" --> "*" Sucursal: administra
    Usuario "*" --> "1..*" Sucursal: asiste a
%% Nuevo Agregado: Calidad y Soporte
    class Queja {
        <<AggregateRoot>>
        -UUID id
        -String descripcion
        -LocalDateTime fechaReporte
        -EstadoQueja estado
        -String respuestaAdmin
        +marcarComoResuelta(respuesta: String): void
    }

    Cliente "1" --> "*" Queja: emite
    Sucursal "1" <-- "*" Queja: ocurre en
%% Procesos Transicionales
    class SolicitudEntrenador {
        <<AggregateRoot>>
        -UUID id
        -LocalDateTime fechaCreacion
        -EstadoSolicitud estado
        -Cliente solicitante
        -Entrenador entrenadorDeseado
        +aprobar(): void
        +rechazar(motivo: String): void
    }

    Cliente "1" --> "*" SolicitudEntrenador: genera
    SolicitudEntrenador "*" --> "1" Entrenador: referida a
%% Agregado: Membresía y Pagos
    class Membresia {
        <<AggregateRoot>>
        -UUID id
        -LocalDate fechaInicio
        -LocalDate fechaVencimiento
        -EstadoMembresia estado
        +registrarPago(p: Pago): void
        +verificarVigencia(): boolean
        +cancelar(): void
    }

    class Pago {
        -UUID idPago
        -float monto
        -LocalDateTime fecha
        -String metodoPago
        +esValido(): boolean
    }

    Cliente "1" --> "0..1" Membresia: posee
    Membresia "1" *-- "*" Pago: historial
%% Agregado: Entrenamiento (Diseño)
    class Rutina {
        <<AggregateRoot>>
        -UUID id
        -String nombre
        -String dificultad
        -boolean esPublica
        -Usuario creador
        +iniciarSesion(): SesionEntrenamiento
        +clonar(): Rutina
    }

    class ConfiguracionEjercicio {
        <<ValueObject>>
        -int seriesObjetivo
        -int repeticionesSugeridas
        -int descansoSegundos
    }

    class Ejercicio {
        -UUID id
        -String nombre
        -String grupoMuscular
        -String urlVideo
    }

    Rutina *-- ConfiguracionEjercicio
    ConfiguracionEjercicio --> Ejercicio
%% Agregado: Entrenamiento (Ejecución)
    class SesionEntrenamiento {
        <<AggregateRoot>>
        -UUID id
        -LocalDateTime fechaInicio
        -LocalDateTime fechaFin
        -EstadoSesion estado
        +agregarSerie(ejercicioId: UUID, peso: float, reps: int, clasificacion: String): void
        +finalizarSesion(): void
    }

    class SerieRealizada {
        <<Entity>>
        -float pesoLevantado
        -int repeticionesHechas
        -String desempenoIntencion
    }

    Cliente "1" --> "*" SesionEntrenamiento: realiza
    SesionEntrenamiento *-- SerieRealizada
    SesionEntrenamiento --> Rutina: basada en
    Cliente "1" --> "1" Membresia: posee
    Entrenador "1" --> "*" Rutina: crea
